{
    "name": "casper-pos-desktop",
    "version": "1.0.0",
    "main": "electron/main-loader.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:next\" \"wait-on tcp:3001 && npm run dev:electron\"",
        "dev:next": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && npx prisma db push --accept-data-loss && next dev -p 3001",
        "dev:electron": "cross-env NODE_ENV=development electron .",
        "build": "next build",
        "electron:build": "npm run build && node scripts/prepare-standalone.js",
        "dist:assets": "node scripts/generate-build-assets.js",
        "compile:bytecode": "cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/compile-bytecode.js",
        "dist": "npm run dist:assets && npm run compile:bytecode && npm run electron:build && electron-builder",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "postinstall": "prisma generate"
    },
    "build": {
        "appId": "com.caspererp.app",
        "productName": "Casper POS",
        "copyright": "Copyright © 2026 Casper POS",
        "asar": true,
        "asarUnpack": [
            ".next/standalone/**/*",
            ".next/standalone/node_modules/**/*",
            "node_modules/prisma/**/*",
            "node_modules/@prisma/**/*",
            "prisma/**/*"
        ],
        "files": [
            "electron/**/*",
            "public/**/*",
            ".next/standalone/**/*",
            ".next/standalone/node_modules/**/*",
            "prisma/**/*",
            "messages/**/*",
            "package.json",
            "node_modules/prisma/**/*",
            "node_modules/@prisma/**/*"
        ],
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "runAfterFinish": true,
            "license": "build/license.txt",
            "installerIcon": "build/installerIcon.ico",
            "uninstallerIcon": "build/uninstallerIcon.ico",
            "installerHeader": "build/installerHeader.bmp",
            "installerSidebar": "build/installerSidebar.bmp",
            "uninstallerSidebar": "build/uninstallerSidebar.bmp",
            "language": "1025"
        }
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "@prisma/debug": "^7.4.1",
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-tabs": "^1.1.13",
        "@tanstack/react-query": "^5.90.21",
        "app-builder-bin": "^4.2.0",
        "arabic-reshaper": "^1.1.0",
        "bcryptjs": "^3.0.3",
        "bidi-js": "^1.0.3",
        "bwip-js": "^4.8.0",
        "bytenode": "^1.5.7",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "decimal.js": "^10.6.0",
        "dexie": "^4.3.0",
        "electron-serve": "^1.3.0",
        "flatpickr": "^4.6.13",
        "fs-extra": "^11.2.0",
        "html2canvas": "^1.4.1",
        "jose": "^6.1.3",
        "jspdf": "^4.2.0",
        "jspdf-autotable": "^5.0.7",
        "lucide-react": "^0.575.0",
        "next": "14.2.3",
        "next-themes": "^0.4.6",
        "prisma": "^5.22.0",
        "qz-tray": "^2.2.5",
        "react": "^18",
        "react-barcode": "^1.6.1",
        "react-day-picker": "^9.13.2",
        "react-dom": "^18",
        "react-hook-form": "^7.71.1",
        "react-virtuoso": "^4.18.1",
        "recharts": "^3.7.0",
        "sonner": "^2.0.7",
        "stream-browserify": "^3.0.0",
        "tailwind-merge": "^3.5.0",
        "use-debounce": "^10.1.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@next/bundle-analyzer": "^14.2.3",
        "@tailwindcss/postcss": "^4.2.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^25.3.0",
        "@types/pako": "^2.0.4",
        "@types/raf": "^3.4.3",
        "@types/react": "^19.2.14",
        "@types/trusted-types": "^2.0.7",
        "concurrently": "^8.2.2",
        "cross-env": "^7.0.3",
        "electron": "^30.0.0",
        "electron-builder": "^26.8.1",
        "jimp": "^1.6.0",
        "postcss": "^8.5.6",
        "sharp": "^0.34.5",
        "tailwindcss": "^4.2.0",
        "to-ico": "^1.1.5",
        "typescript": "^5",
        "wait-on": "^7.2.0"
    }
}